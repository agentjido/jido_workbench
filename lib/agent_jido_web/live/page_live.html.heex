<%= case @layout_type do %>
  <% :docs_shell -> %>
    <%!-- Docs layout (sidebar + TOC) --%>
    <div class="docs-shell h-dvh min-h-screen bg-background flex flex-col overflow-hidden">
      <.docs_header current_path={@request_path} />
      <AgentJidoWeb.Jido.Nav.primary_nav_modals
        current_scope={@current_scope}
        analytics_identity={@analytics_identity}
      />
      <.docs_secondary_nav current_path={@request_path} tabs={@docs_secondary_tabs || []} />

      <div class="docs-scrollbar flex-1 min-h-0 overflow-y-auto">
        <div class="flex min-h-full">
          <.docs_sidebar
            nav={@docs_sidebar_nav || []}
            current_path={@request_path}
            open={@sidebar_open}
          />

          <main class="docs-main flex-1 min-w-0">
            <div class="mx-auto w-full max-w-[1040px] px-6 py-10 lg:px-10 xl:px-14">
              <%= if @selected_document do %>
                <div class="space-y-10">
                  <div class="docs-page-header space-y-4">
                    <h1 class="text-3xl font-bold tracking-tight text-foreground">
                      {@selected_document.title}
                    </h1>
                    <p class="max-w-[78ch] text-[15px] leading-relaxed text-muted-foreground">
                      {@selected_document.description}
                    </p>
                  </div>

                  <section :if={@toc && @toc != []} class="xl:hidden">
                    <div class="rounded-md border border-border bg-card/60 p-3">
                      <div class="mb-2 text-[10px] font-bold tracking-[0.1em] uppercase text-muted-foreground">
                        Jump To Section
                      </div>
                      <div class="docs-scrollbar flex gap-2 overflow-x-auto pb-1">
                        <%= for heading <- @toc |> Enum.filter(&(&1.level <= 2)) |> Enum.take(10) do %>
                          <a
                            href={"##{heading.id}"}
                            class="whitespace-nowrap rounded border border-border bg-background/60 px-2.5 py-1 text-[11px] text-muted-foreground transition-colors hover:border-border-strong hover:text-foreground"
                          >
                            {heading.title}
                          </a>
                        <% end %>
                      </div>
                    </div>
                  </section>

                  <div id="docs-content" class="docs-prose prose docs-document max-w-none">
                    {raw(@selected_document.body)}
                  </div>
                </div>
              <% else %>
                <%!-- Docs Index --%>
                <div class="space-y-12">
                  <%!-- Hero --%>
                  <section class="mb-12">
                    <h1 class="text-3xl font-bold mb-4 tracking-tight">
                      Jido Documentation
                    </h1>
                    <p class="copy-measure mb-6 text-[15px] leading-relaxed text-muted-foreground">
                      Everything you need to build and run production-grade autonomous agents on the BEAM.
                      From first install to scaling <span class="text-primary">10,000+ supervised agents</span> on a single node.
                    </p>
                    <div class="rounded-md p-5 bg-primary/[0.08] border border-primary/20">
                      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                        <div>
                          <div class="text-xs font-semibold text-primary mb-1">
                            ✨ Get started in one command
                          </div>
                          <div class="text-[13px] text-muted-foreground">
                            Auto-configures deps, supervision tree, and config
                          </div>
                        </div>
                        <div class="px-4 py-2.5 rounded bg-code-bg border border-border font-mono text-[13px]">
                          <span class="text-muted-foreground">$ </span>
                          <span class="text-accent-cyan">mix</span>
                          <span class="text-foreground"> igniter.install jido</span>
                        </div>
                      </div>
                    </div>

                    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
                      <.link navigate="/docs/getting-started/elixir-developers" class="block group">
                        <div class="rounded-md border border-border bg-card p-4 flex items-start gap-3.5 transition-all duration-200 hover:border-accent-green hover:-translate-y-0.5">
                          <div class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-accent-green/10 border border-accent-green/30 shrink-0 mt-0.5">
                            <.icon name="hero-command-line" class="h-4 w-4 text-accent-green" />
                          </div>
                          <div>
                            <div class="text-sm font-semibold text-foreground mb-1 group-hover:text-accent-green transition-colors">
                              I know Elixir
                            </div>
                            <p class="text-xs text-muted-foreground leading-relaxed">
                              Map Jido's architecture to OTP patterns you already know, then jump straight into building.
                            </p>
                          </div>
                        </div>
                      </.link>
                      <.link navigate="/docs/getting-started/new-to-elixir" class="block group">
                        <div class="rounded-md border border-border bg-card p-4 flex items-start gap-3.5 transition-all duration-200 hover:border-accent-cyan hover:-translate-y-0.5">
                          <div class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-accent-cyan/10 border border-accent-cyan/30 shrink-0 mt-0.5">
                            <.icon name="hero-academic-cap" class="h-4 w-4 text-accent-cyan" />
                          </div>
                          <div>
                            <div class="text-sm font-semibold text-foreground mb-1 group-hover:text-accent-cyan transition-colors">
                              I'm new to Elixir
                            </div>
                            <p class="text-xs text-muted-foreground leading-relaxed">
                              Get the essential Elixir context you need to follow the tutorials and read Jido code confidently.
                            </p>
                          </div>
                        </div>
                      </.link>
                    </div>
                  </section>

                  <%!-- Get Started --%>
                  <section id="get-started" class="mb-12">
                    <h2 class="text-lg font-bold mb-5 flex items-center gap-2">
                      <span class="text-primary">#</span> Get Started
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      <.numbered_card
                        number="1"
                        title="Install & Setup"
                        description="Add Jido to a Mix project, configure dependencies, and verify everything compiles."
                        href="/docs/getting-started/installation"
                      />
                      <.numbered_card
                        number="2"
                        title="Your First Agent"
                        description="Define an agent with typed state and actions — no LLM required."
                        href="/docs/getting-started/first-agent"
                      />
                      <.numbered_card
                        number="3"
                        title="Add LLM Reasoning"
                        description="Wire up an LLM so your agent can reason about instructions and use tools."
                        href="/docs/getting-started/first-llm-agent"
                      />
                      <.numbered_card
                        number="4"
                        title="Build a Workflow"
                        description="Compose actions into a multi-step workflow that runs as a single unit."
                        href="/docs/learn/first-workflow"
                      />
                    </div>
                  </section>

                  <%!-- Documentation sections — driven by content system --%>
                  <section id="documentation" class="mb-12">
                    <h2 class="text-lg font-bold mb-5 flex items-center gap-2">
                      <span class="text-accent-yellow">#</span> Documentation
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                      <%= for section_page <- @docs_sections do %>
                        <% color = AgentJidoWeb.PageLive.section_color(section_page) %>
                        <% count = AgentJidoWeb.PageLive.section_page_count(section_page) %>
                        <.link navigate={AgentJido.Pages.route_for(section_page)} class="block group h-full">
                          <div class={
                            "bg-card border border-border rounded-md p-5 h-full transition-all duration-200 hover:-translate-y-0.5 " <>
                            section_hover_class(color)
                          }>
                            <div class="flex items-center justify-between mb-3">
                              <div class={"inline-flex items-center justify-center w-8 h-8 rounded-md " <> section_color_classes(color)}>
                                <.icon name={AgentJidoWeb.PageLive.section_icon(section_page)} class={"h-4 w-4 " <> section_icon_color(color)} />
                              </div>
                              <span :if={count > 0} class="text-[10px] px-2 py-0.5 rounded bg-elevated text-muted-foreground">
                                {count} pages
                              </span>
                            </div>
                            <div class="text-sm font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
                              {Map.get(section_page, :menu_label) || section_page.title}
                            </div>
                            <p class="text-xs text-muted-foreground leading-relaxed">
                              {section_page.description}
                            </p>
                          </div>
                        </.link>
                      <% end %>
                    </div>
                  </section>

                  <%!-- Package Ecosystem --%>
                  <section id="package-ecosystem" class="mb-12">
                    <div class="flex items-center justify-between mb-5">
                      <h2 class="text-lg font-bold flex items-center gap-2">
                        <span class="text-accent-cyan">#</span> Package Ecosystem
                      </h2>
                      <.link navigate="/ecosystem" class="text-[11px] text-muted-foreground hover:text-primary transition-colors">
                        View all →
                      </.link>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      <.icon_card
                        icon="◈"
                        title="jido"
                        description="BEAM-native bot framework with OTP supervision. Run thousands of agents per node."
                        color="green"
                        href="/ecosystem/jido"
                      />
                      <.icon_card
                        icon="⚡"
                        title="jido_ai"
                        description="LLM-powered agents with token budgets, tool calling, and streaming support."
                        color="yellow"
                        href="/ecosystem/jido_ai"
                      />
                      <.icon_card
                        icon="⟳"
                        title="req_llm"
                        description="HTTP client for LLM APIs. Retries, rate limiting, and multi-provider support."
                        color="cyan"
                        href="/ecosystem/req_llm"
                      />
                      <.icon_card
                        icon="⚙"
                        title="jido_browser"
                        description="Browser automation tools for navigation, extraction, forms, and screenshots."
                        color="red"
                        href="/ecosystem/jido_browser"
                      />
                    </div>
                  </section>

                  <%!-- Community --%>
                  <section id="community" class="mb-12">
                    <h2 class="text-lg font-bold mb-5 flex items-center gap-2">
                      <span class="text-accent-cyan">#</span> Join the Community
                    </h2>
                    <div class="rounded-md p-6 bg-accent-cyan/[0.08] border border-accent-cyan/20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                      <div>
                        <div class="text-sm font-semibold text-foreground mb-1">
                          Questions? Need help debugging production issues?
                        </div>
                        <div class="text-[13px] text-muted-foreground">
                          Reach out on ElixirForum, GitHub Discussions, or Discord.
                        </div>
                      </div>
                      <div class="flex gap-3">
                        <a
                          href="https://discord.gg/agentjido"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="px-5 py-2.5 rounded text-xs font-semibold bg-accent-cyan text-background hover:opacity-90 transition-opacity"
                        >
                          Join Discord
                        </a>
                        <a
                          href="https://github.com/agentjido/jido/issues"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="px-5 py-2.5 rounded text-xs font-medium border border-accent-cyan text-accent-cyan hover:bg-accent-cyan/10 transition-colors"
                        >
                          GitHub Issues
                        </a>
                      </div>
                    </div>
                  </section>
                </div>
              <% end %>
            </div>

            <%= if @selected_document do %>
              <%!-- Content-area footer: edit link --%>
              <div class="mx-auto w-full max-w-[1040px] px-6 lg:px-10 xl:px-14 pb-10">
                <div class="border-t border-border pt-6">
                  <div class="text-[11px] text-muted-foreground">
                    <%= if @selected_document.github_url do %>
                      <a
                        href={String.replace(@selected_document.github_url, "/blob/", "/edit/")}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-foreground transition-colors"
                      >
                        Edit this page →
                      </a>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </main>

          <%= if @toc && @toc != [] do %>
            <.docs_right_sidebar
              toc={@toc}
              selected_document={@selected_document}
              docs_feedback={@docs_feedback}
            />
          <% end %>
        </div>

        <%!-- Full-width marketing footer — outside the sidebar flex row --%>
        <AgentJidoWeb.Jido.MarketingLayouts.marketing_footer />
      </div>
    </div>
  <% :training_index -> %>
    <%!-- Training index --%>
    <.marketing_layout
      current_path="/training"
      current_scope={@current_scope}
      analytics_identity={@analytics_identity}
    >
      <div class="container max-w-[1000px] mx-auto px-6 py-12">
        <section class="text-center mb-16">
          <div class="inline-block px-4 py-2 rounded mb-5 bg-primary/10 border border-primary/30">
            <span class="text-primary text-[11px] font-semibold tracking-widest uppercase">
              TRAINING TRACK
            </span>
          </div>
          <h1 class="text-4xl font-bold mb-4">
            Practical Jido training for <span class="text-primary">Elixir engineers</span>
          </h1>
          <p class="copy-measure-wide mx-auto text-lg text-muted-foreground">
            Move from fundamentals to production patterns through hands-on modules, each with a concrete exercise and validation checklist.
          </p>
        </section>

        <%= for {track, modules} <- @track_groups do %>
          <section class="mb-16">
            <div class="flex justify-between items-center mb-6">
              <span class="text-sm font-bold tracking-wider uppercase">
                {AgentJidoWeb.PageLive.track_label(track)}
              </span>
              <span class="text-[10px] px-2 py-1 rounded bg-accent-cyan/10 border border-accent-cyan/30 text-accent-cyan font-semibold">
                {length(modules)} module{if length(modules) == 1, do: "", else: "s"}
              </span>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
              <%= for mod <- modules do %>
                <.link navigate={"/training/#{mod.id}"} class="feature-card group block">
                  <div class="flex justify-between items-start mb-3 gap-2">
                    <span class={"text-[10px] px-2 py-0.5 rounded font-semibold uppercase #{AgentJidoWeb.PageLive.difficulty_badge(mod.difficulty)}"}>
                      {mod.difficulty}
                    </span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-elevated text-muted-foreground">
                      {mod.duration_minutes} min
                    </span>
                  </div>

                  <h3 class="font-bold text-[15px] mb-2 group-hover:text-primary transition-colors">
                    {mod.title}
                  </h3>
                  <p class="text-muted-foreground text-xs leading-relaxed mb-4">
                    {mod.description}
                  </p>

                  <div class="flex gap-2 flex-wrap mb-4">
                    <span class="text-[10px] px-2 py-0.5 rounded bg-primary/10 text-primary">
                      {length(mod.prerequisites)} prerequisite{if length(mod.prerequisites) == 1, do: "", else: "s"}
                    </span>
                    <%= for tag <- mod.tags do %>
                      <span class="text-[10px] px-2 py-0.5 rounded bg-elevated text-muted-foreground">
                        {tag}
                      </span>
                    <% end %>
                  </div>

                  <span class="text-xs font-semibold text-primary">OPEN MODULE →</span>
                </.link>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </.marketing_layout>
  <% :training_shell -> %>
    <%!-- Training module detail --%>
    <.marketing_layout
      current_path="/training"
      current_scope={@current_scope}
      analytics_identity={@analytics_identity}
    >
      <div class="container max-w-[1000px] mx-auto px-6 py-12">
        <div class="mb-8">
          <.link navigate="/training" class="text-xs text-muted-foreground hover:text-primary transition-colors">
            ← back to training
          </.link>
        </div>

        <section class="mb-10">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            <span class="text-[10px] px-2 py-1 rounded bg-primary/10 border border-primary/30 text-primary font-semibold uppercase tracking-wider">
              {AgentJidoWeb.PageLive.track_label(@page.track)}
            </span>
            <span class={"text-[10px] px-2 py-1 rounded font-semibold uppercase tracking-wider #{AgentJidoWeb.PageLive.difficulty_class(@page.difficulty)}"}>
              {@page.difficulty}
            </span>
            <span class="text-[10px] px-2 py-1 rounded bg-elevated border border-border text-muted-foreground">
              {@page.duration_minutes} min
            </span>
          </div>

          <h1 class="text-3xl font-bold tracking-tight mb-3">{@page.title}</h1>
          <p class="text-sm text-secondary-foreground leading-relaxed max-w-[820px]">
            {@page.description}
          </p>

          <a
            :if={@markdown_action}
            href={@markdown_action.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex text-xs font-semibold uppercase tracking-wide text-primary hover:opacity-80 transition-opacity"
          >
            {@markdown_action.label} →
          </a>

          <div :if={@page.learning_outcomes != []} class="mt-5">
            <h2 class="text-xs font-bold tracking-wider mb-2">LEARNING OUTCOMES</h2>
            <ul class="space-y-1">
              <%= for outcome <- @page.learning_outcomes do %>
                <li class="text-xs text-muted-foreground">• {outcome}</li>
              <% end %>
            </ul>
          </div>
        </section>

        <section class="mb-12">
          <article class="docs-prose prose max-w-none text-sm leading-relaxed">
            {Phoenix.HTML.raw(@page.body)}
          </article>
        </section>

        <section class="grid md:grid-cols-2 gap-4">
          <%= if assigns[:previous_module] do %>
            <.link
              navigate={"/training/#{@previous_module.id}"}
              class="feature-card block"
            >
              <div class="text-[10px] text-muted-foreground uppercase mb-1">Previous Module</div>
              <div class="text-sm font-semibold text-foreground">{@previous_module.title}</div>
            </.link>
          <% end %>

          <%= if assigns[:next_module] do %>
            <.link
              navigate={"/training/#{@next_module.id}"}
              class="feature-card block md:text-right"
            >
              <div class="text-[10px] text-muted-foreground uppercase mb-1">Next Module</div>
              <div class="text-sm font-semibold text-foreground">{@next_module.title}</div>
            </.link>
          <% end %>
        </section>
      </div>
    </.marketing_layout>
  <% :marketing_shell -> %>
    <%!-- Marketing/generic layout --%>
    <.marketing_layout
      current_path={@request_path}
      current_scope={@current_scope}
      analytics_identity={@analytics_identity}
    >
      <div class="container max-w-[1000px] mx-auto px-6 py-12">
        <%= if @page do %>
          <div class="mb-8">
            <.link
              navigate={"/#{@category}"}
              class="text-xs text-muted-foreground hover:text-primary transition-colors"
            >
              ← back to {Phoenix.Naming.humanize(@category)}
            </.link>
          </div>

          <div class="space-y-8">
            <div class="space-y-4">
              <h1 class="text-3xl font-bold tracking-tight text-foreground">{@page.title}</h1>
              <p :if={@page.description} class="text-lg text-muted-foreground">
                {@page.description}
              </p>
              <a
                :if={@markdown_action}
                href={@markdown_action.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex text-xs font-semibold uppercase tracking-wide text-primary hover:opacity-80 transition-opacity"
              >
                {@markdown_action.label} →
              </a>
            </div>
            <%= if @category == :features do %>
              <section class="grid sm:grid-cols-3 gap-3">
                <div class="feature-card py-4">
                  <div class="text-[10px] uppercase tracking-wider text-muted-foreground mb-1">Audience</div>
                  <div class="text-sm font-semibold text-foreground">
                    {@page.audience |> to_string() |> Phoenix.Naming.humanize()}
                  </div>
                </div>
                <div class="feature-card py-4">
                  <div class="text-[10px] uppercase tracking-wider text-muted-foreground mb-1">Document type</div>
                  <div class="text-sm font-semibold text-foreground">
                    {@page.doc_type |> to_string() |> Phoenix.Naming.humanize()}
                  </div>
                </div>
                <div class="feature-card py-4">
                  <div class="text-[10px] uppercase tracking-wider text-muted-foreground mb-1">Read time</div>
                  <div class="text-sm font-semibold text-foreground">
                    {@page.reading_time_minutes} min
                  </div>
                </div>
              </section>

              <section :if={@toc && @toc != []} class="feature-card py-4">
                <div class="text-[10px] uppercase tracking-wider text-muted-foreground mb-3">Jump to section</div>
                <div class="flex flex-wrap gap-2">
                  <%= for heading <- @toc |> Enum.filter(&(&1.level <= 2)) |> Enum.take(8) do %>
                    <a
                      href={"##{heading.id}"}
                      class="text-[11px] px-2 py-1 rounded border border-border bg-elevated text-foreground hover:border-primary/40 transition-colors"
                    >
                      {heading.title}
                    </a>
                  <% end %>
                </div>
              </section>
            <% end %>
            <article class="docs-prose prose max-w-none text-sm leading-relaxed">
              {Phoenix.HTML.raw(@page.body)}
            </article>
          </div>
        <% else %>
          <h1 class="text-3xl font-bold mb-8">{Phoenix.Naming.humanize(@category)}</h1>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <%= for pg <- assigns[:pages] || [] do %>
              <.link navigate={AgentJido.Pages.route_for(pg)} class="feature-card group block">
                <h3 class="font-bold text-[15px] mb-2 group-hover:text-primary transition-colors">
                  {pg.title}
                </h3>
                <p :if={pg.description} class="text-muted-foreground text-xs leading-relaxed">
                  {pg.description}
                </p>
              </.link>
            <% end %>
          </div>
        <% end %>
      </div>
    </.marketing_layout>
<% end %>
